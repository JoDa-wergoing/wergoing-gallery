#: admin/settings-page.php
msgid "HiGallery Settings"
msgstr "HiGallery instellingen"

#: admin/settings-page.php
msgid "Configuration"
msgstr "Configuratie"

#: admin/settings-page.php
msgid "Client ID"
msgstr "Client ID"

#: admin/settings-page.php
msgid "Client Secret"
msgstr "Client secret"

#: admin/settings-page.php
msgid "Enter new secret"
msgstr "Voer nieuw secret in"

#: admin/settings-page.php
msgid "The client secret is stored securely. Enter a new value to replace it."
msgstr "Het client secret is veilig opgeslagen. Voer een nieuwe waarde in om het te vervangen."

#: admin/settings-page.php
msgid "HiGallery root folder"
msgstr "HiGallery hoofdmap"

#: admin/settings-page.php
msgid "Thumbnail width (px)"
msgstr "Miniatuur breedte (px)"

#: admin/settings-page.php
msgid "Test mode"
msgstr "Testmodus"

#: admin/settings-page.php
msgid "Use demo albums without HiDrive connection"
msgstr "Demo-albums gebruiken zonder HiDrive-verbinding"

#: admin/settings-page.php
msgid "OAuth2 connection"
msgstr "OAuth2-verbinding"

#: admin/settings-page.php
msgid "Connect HiGallery to your HiDrive account:"
msgstr "Verbind HiGallery met je HiDrive-account:"

#: admin/settings-page.php
msgid "Connect to HiDrive"
msgstr "Verbind met HiDrive"

#: includes/gallery-shortcode.php
#: includes/all-albums-shortcode.php
msgid "No HiDrive connection. Please connect HiDrive first."
msgstr "Geen HiDrive-verbinding. Maak eerst verbinding met HiDrive."

#: includes/gallery-shortcode.php
msgid "Cannot load gallery."
msgstr "Kan de galerij niet laden."

#: includes/gallery-shortcode.php
#: includes/all-albums-shortcode.php
msgid "No albums found."
msgstr "Geen albums gevonden."

#: includes/gallery-shortcode.php
msgid "No albums matched the filter."
msgstr "Geen albums gevonden die overeenkomen met het filter."

#: includes/gallery-shortcode.php
msgid "No images found in this album."
msgstr "Geen afbeeldingen gevonden in dit album."

#: includes/gallery-shortcode.php
msgid "No photos found in this album."
msgstr "Geen foto's gevonden in dit album."

#: includes/gutenberg-block.php
msgid "No albums selected."
msgstr "Geen albums geselecteerd."

#: includes/gutenberg-block.php
#: includes/proxy-endpoint.php
msgid "No valid access token."
msgstr "Geen geldig toegangstoken."

#: includes/proxy-endpoint.php
msgid "Invalid or missing path parameter."
msgstr "Ongeldig of ontbrekend padparameter."

#: includes/proxy-endpoint.php
msgid "Access to this path is not allowed."
msgstr "Toegang tot dit pad is niet toegestaan."

#: includes/proxy-endpoint.php
msgid "No valid HiDrive access token available."
msgstr "Geen geldig HiDrive-toegangstoken beschikbaar."

#: includes/proxy-endpoint.php
msgid "Empty response from HiDrive."
msgstr "Lege respons van HiDrive."

#: includes/api-client.php
msgid "Path and token are required."
msgstr "Pad en token zijn verplicht."

#: includes/api-client.php
#. translators: %d: HTTP status code returned by HiDrive
msgid "HiDrive returned status %d."
msgstr "HiDrive retourneerde statuscode %d."

#: includes/oauth.php
msgid "Client ID or secret is missing."
msgstr "Client ID of secret ontbreekt."

#: includes/oauth.php
msgid "Invalid token response from HiDrive."
msgstr "Ongeldige tokenrespons van HiDrive."

#: includes/proxy-endpoint.php
msgid "Too many requests. Please try again later."
msgstr "Te veel verzoeken. Probeer het later opnieuw."

#: admin/settings-page.php
msgid "HiGallery: Client ID and secret are not configured."
msgstr "HiGallery: Client ID en secret zijn niet ingesteld."

#: admin/settings-page.php
msgid "Go to settings"
msgstr "Ga naar instellingen"

#: admin/settings-page.php
msgid "HiGallery: Not connected to HiDrive. Galleries will not load."
msgstr "HiGallery: Niet verbonden met HiDrive. Galerijen worden niet geladen."

#: admin/settings-page.php
msgid "Reconnect"
msgstr "Opnieuw verbinden"

#: admin/settings-page.php
msgid "HiDrive: connected"
msgstr "HiDrive: verbonden"

#: admin/settings-page.php
msgid "Your HiDrive account is linked and galleries will load normally."
msgstr "Je HiDrive-account is gekoppeld en galerijen worden normaal geladen."

#: admin/settings-page.php
msgid "HiDrive: not connected"
msgstr "HiDrive: niet verbonden"

#: admin/settings-page.php
msgid "Credentials are saved but no valid token exists. Use the button below to reconnect."
msgstr "Inloggegevens zijn opgeslagen maar er is geen geldig token. Gebruik de knop hieronder om opnieuw te verbinden."

#: admin/settings-page.php
msgid "HiDrive: not configured"
msgstr "HiDrive: niet geconfigureerd"

#: admin/settings-page.php
msgid "Enter your Client ID and Client Secret below, then connect to HiDrive."
msgstr "Voer hieronder je Client ID en Client Secret in en verbind daarna met HiDrive."
